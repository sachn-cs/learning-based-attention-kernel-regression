[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg,
    .venv,
    venv,
    .tox,
    .mypy_cache,
    .pytest_cache,
    docs/_build,
    benchmarks/compare_approximations.py,
    benchmarks/compare_baseline.py,
    benchmarks/reproducible_benchmarks.py
