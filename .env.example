# LAKER Environment Configuration
# ================================
# This file contains optional environment variables for configuring LAKER.
# Copy this file to .env and fill in the values as needed.

# Device configuration
# Set to "cpu", "cuda", or "mps" (Apple Silicon)
# LAKER_DEVICE=cpu

# Default dtype for computations
# Set to "float32" or "float64"
# LAKER_DTYPE=float32

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LAKER_LOG_LEVEL=INFO

# Codecov token for CI coverage reporting
# CODECOV_TOKEN=
